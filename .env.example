# Database location (optional). Default: $XDG_DATA_HOME/ygg/ygg.db
# (fallback ~/.local/share/ygg/ygg.db). YGG_DB_PATH takes a plain path;
# DATABASE_URL still works with a sqlite:// URL for compatibility.
# YGG_DB_PATH=/path/to/ygg.db
# DATABASE_URL=sqlite:///path/to/ygg.db
CONTEXT_LIMIT_TOKENS=250000
CONTEXT_HARD_CAP_TOKENS=300000
LOCK_TTL_SECS=300
HEARTBEAT_INTERVAL_SECS=60
WATCHER_INTERVAL_SECS=30
RTK_BINARY_PATH=rtk
RUST_LOG=ygg=info

# ── hermes-gateway integration (ygg hermes / scheduler hermes backend) ──
# Base URL of the hermes-gateway router. Unset disables all hermes features.
# HERMES_GATEWAY_URL=http://hermes-gateway.ph.ca:8642
# Bearer token for the OpenAI-compatible + task API (/v1/*). Scope must allow
# the agent you address.
# HERMES_GATEWAY_TOKEN=hgw_YOUR_GATEWAY_KEY
# Separate bearer for the ops dashboard API (/dashboard/api/*), used by
# `ygg hermes status`.
# HERMES_DASHBOARD_TOKEN=hgwd_YOUR_DASHBOARD_KEY
# Gateway agent a bare `hermes` backend selector routes to (default feature-dev).
# YGG_HERMES_DEFAULT_AGENT=feature-dev
# Poll interval (seconds) for reconciling running hermes-backed runs (default 5).
# YGG_HERMES_POLL_SECS=5
